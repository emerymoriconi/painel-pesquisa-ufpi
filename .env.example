# ──────────────────────────────────────────────────────────────────────────────
# Arquivo único de configuração — cobre tanto o Docker Compose quanto o dev local
# Copie para .env e preencha os valores antes de rodar o projeto.
# O arquivo .env NUNCA deve ser commitado no git.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (serviço db no Docker Compose) ──────────────────────────────
POSTGRES_USER=painel
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
POSTGRES_DB=pesquisa

# ── Backend ────────────────────────────────────────────────────────────────
# Para dev local (uvicorn direto): aponta para localhost
# No Docker Compose o container api usa a URL construída em docker-compose.yml
# (hostname 'db'), ignorando este valor.
DATABASE_URL=postgresql://painel:TROQUE_ESTA_SENHA@localhost:5432/pesquisa

# JWT — gere uma chave aleatória com:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_ESTA_CHAVE_SECRETA

# Usuário administrador (login via variável de ambiente)
ADMIN_USERNAME=admin
# Hash bcrypt da senha. Gere com:
#   python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('SUA_SENHA'))"
ADMIN_PASSWORD_HASH=

# ── Dashboard ──────────────────────────────────────────────────────────────
ULTIMA_ATUALIZACAO=08/02/2026
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173
